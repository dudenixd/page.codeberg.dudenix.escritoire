{
    "id": "page.codeberg.dudenix.escritoire",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "command": "escritoire",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin",
        "env": {
            "CARGO_REGISTRIES_CRATES_IO_PROTOCOL": "sparse"
        }
    },
    "modules": [
        {
            "name": "escritoire",
            "buildsystem": "meson",
            "run-tests": false,
            "sources": [
                {
                    "type": "archive",
                    "url": "https://codeberg.org/dudenix/escritoire/releases/download/v1.1.1/escritoire-1.1.1.tar.xz",
                    "sha256": "41ab6c006d4cc2af71afb026d1381982198a1c1a3ba1181c3be8f111728bd9dc"
                }
            ]
        }
    ]
}
