{
    "id": "page.codeberg.dudenix.escritoire",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "command": "escritoire",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin",
        "env": {
            "CARGO_REGISTRIES_CRATES_IO_PROTOCOL": "sparse"
        }
    },
    "modules": [
        {
            "name": "escritoire",
            "buildsystem": "meson",
            "run-tests": false,
            "sources": [
                {
                    "type": "archive",
                    "url": "https://codeberg.org/dudenix/escritoire/releases/download/v1.1.2/escritoire-1.1.2.tar.xz",
                    "sha256": "e0f8545cec64e30007904f64c37ab82cccf0b361b46508911bdef16819f7c277"
                }
            ]
        }
    ]
}
